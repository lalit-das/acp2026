#!/usr/bin/env bash
# bats-minimal: bats-core compatible test runner
BATS_VERSION="1.10.0-minimal"
if [[ -t 1 ]]; then R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m' C='\033[0;36m' B='\033[1m' E='\033[0m'
else R='' G='' Y='' C='' B='' E=''; fi
TOTAL=0; PASSED=0; FAILED=0; SKIPPED=0; FAILED_TESTS=()
BATS_TMPDIR="${TMPDIR:-/tmp}/bats-$$"

# Use python to parse @test blocks, writing each to a numbered file
# Writes: $dir/count, $dir/0/name, $dir/0/body, $dir/1/name, ...
parse_tests() {
  local file="$1" dir="$2"
  python - "$file" "$dir" <<'PYEOF'
import sys, re, os
src = open(sys.argv[1]).read()
out = sys.argv[2]
lines = src.splitlines(); i = 0; idx = 0
while i < len(lines):
    m = re.match(r"""^[ \t]*@test[ \t]+['"](.*?)['"]\s*(\{?)\s*$""", lines[i])
    if m:
        name = m.group(1); body = []; depth = 1 if m.group(2)=='{' else 0; i += 1
        while i < len(lines):
            line = lines[i]; opens = line.count('{'); closes = line.count('}')
            depth += opens - closes
            if depth <= 0:
                stripped = line.strip()
                if stripped != '}': body.append(line[:line.rfind('}')])
                i += 1; break
            else: body.append(line); i += 1
        d = os.path.join(out, str(idx)); os.makedirs(d, exist_ok=True)
        open(os.path.join(d,'name'),'w').write(name)
        open(os.path.join(d,'body'),'w').write('\n'.join(body))
        idx += 1
    else: i += 1
open(os.path.join(out,'count'),'w').write(str(idx))
PYEOF
}

extract_helpers() {
  python - "$1" <<'PYEOF'
import sys, re
lines = open(sys.argv[1]).readlines()
i = 0; out = []
while i < len(lines):
    if re.match(r"""^[ \t]*@test[ \t]+['"](.*?)['"]""", lines[i]):
        depth = 0
        while i < len(lines):
            depth += lines[i].count('{') - lines[i].count('}')
            i += 1
            if depth <= 0: break
    else: out.append(lines[i]); i += 1
print(''.join(out), end='')
PYEOF
}

run_file() {
  local file="$1" filter="${2:-}"
  [[ -f "$file" ]] || { echo "File not found: $file" >&2; return 1; }
  local helpers; helpers=$(extract_helpers "$file")
  echo -e "${B}${C}$(basename "$file")${E}"
  local pdir="$BATS_TMPDIR/parsed_$$"; mkdir -p "$pdir"
  parse_tests "$file" "$pdir"
  local count; count=$(cat "$pdir/count" 2>/dev/null || echo 0)
  [[ "$count" -eq 0 ]] && { echo -e "  ${Y}(no tests found)${E}"; echo ""; return; }
  local i=0
  while [[ $i -lt $count ]]; do
    local name; name=$(cat "$pdir/$i/name")
    local body; body=$(cat "$pdir/$i/body")
    i=$((i+1))
    [[ -n "$filter" ]] && ! echo "$name" | grep -qE "$filter" 2>/dev/null && continue
    TOTAL=$((TOTAL+1))
    local tmp="$BATS_TMPDIR/t${i}_$$.sh"
    {
      echo '#!/usr/bin/env bash'
      echo 'set -euo pipefail'
      printf 'BATS_TEST_DIRNAME=%q\n' "$(dirname "$(realpath "$file")")"
      cat <<'HELPER'
run(){ status=0; output=""; lines=()
  output=$("$@" 2>&1)||status=$?
  while IFS= read -r _l; do lines+=("$_l"); done <<<"$output"; }
skip(){ echo "SKIP:${1:-}"; exit 254; }
HELPER
      echo "$helpers"
      echo 'declare -f setup &>/dev/null && setup || true'
      echo "$body"
      echo 'declare -f teardown &>/dev/null && teardown || true'
    } > "$tmp"
    local out st=0; out=$(bash "$tmp" 2>&1) || st=$?; rm -f "$tmp"
    if   [[ $st -eq 254 ]]; then echo -e "  ${Y}⊙ SKIP${E} $name"; SKIPPED=$((SKIPPED+1))
    elif [[ $st -eq 0   ]]; then echo -e "  ${G}✓${E} $name";       PASSED=$((PASSED+1))
    else
      echo -e "  ${R}✗ FAIL${E} $name"; FAILED=$((FAILED+1)); FAILED_TESTS+=("$name")
      [[ -n "$out" ]] && { echo -e "${R}    ── output ──────────────────────────────────────────${E}"; echo "$out"|sed 's/^/    /'; echo -e "${R}    ────────────────────────────────────────────────────${E}"; }
    fi
  done
  rm -rf "$pdir"; echo ""
}

main() {
  local files=() filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)    echo "Usage: bats [--filter <re>] file.bats ..."; exit 0 ;;
      -v|--version) echo "bats-minimal $BATS_VERSION"; exit 0 ;;
      -p|--pretty|-t|--tap) shift ;;
      --filter)     filter="$2"; shift 2 ;;
      -*)           echo "Unknown: $1">&2; exit 1 ;;
      *)            files+=("$1"); shift ;;
    esac
  done
  [[ ${#files[@]} -gt 0 ]] || { echo "Usage: bats file.bats ...">&2; exit 1; }
  mkdir -p "$BATS_TMPDIR"; trap 'rm -rf "$BATS_TMPDIR"' EXIT
  echo ""
  for f in "${files[@]}"; do run_file "$f" "$filter"; done
  echo -e "${B}═══════════════════════════════════════════════════${E}"
  echo -e "${B} Results: $TOTAL tests  |  ${G}$PASSED passed${E}${B}  |  ${R}$FAILED failed${E}${B}  |  ${Y}$SKIPPED skipped${E}"
  echo -e "${B}═══════════════════════════════════════════════════${E}"
  [[ ${#FAILED_TESTS[@]} -gt 0 ]] && { echo -e "\n${R}Failed tests:${E}"; for t in "${FAILED_TESTS[@]}"; do echo -e "  ${R}✗${E} $t"; done; echo ""; }
  [[ $FAILED -eq 0 ]]
}
main "$@"
